{
  "expo": {
    "name": "ERHAN FIT",
    "slug": "erhan-fit",
    "version": "1.0.8",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "erhanfit",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.erhan.fit"
    },
    "android": {
      "package": "com.erhan.fit",
      "versionCode": 8,
      "permissions": [
        "REQUEST_INSTALL_PACKAGES",
        "INTERNET"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-asset",
      "expo-image",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#A855F7"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ERHAN FIT antrenman ve diyet resimlerinizi yüklemek için galeri erişimi ister."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "erhan-fit-local"
      }
    }
  }
}
